[application]
config/name="OpenCode Office"
config/description="3D Office World for OpenCode OS"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.0", "Forward Plus")

[rendering]
renderer/rendering_method="forward_plus"
environment/default_environment="res://assets/default_env.tres"
anti_aliasing/quality/msaa=2
shadows/atlas/size=8192

[display]
window/size/viewport_width=1600
window/size/viewport_height=900
window/size/transparent=true
window/size/borderless=true
window/size/always_on_top=true
window/per_pixel_transparency/allowed=true
window/mouse_capture/confine_mouse_to_window=true

[input]
ui_accept={ "deadzone": 0.5, "events": [ { "keycode": 4194309, "type": 0 } ] }
