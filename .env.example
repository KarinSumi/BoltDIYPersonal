# === REQUIRED ===
OVERLAY_AUTH=                        # Bearer token for API auth (generate: node -e "crypto.randomBytes(24).toString('hex')")

# === DAEMON ===
DAEMON_PORT=8787                     # HTTP/WS port
HOST=127.0.0.1                       # Listen address

# === AI PROVIDER (pick one) ===
# OpenAI-compatible
OPENCODE_API_KEY=                    # Your API key
OPENCODE_API_BASE_URL=               # e.g. https://api.openai.com/v1
OPENCODE_MODEL=                      # e.g. gpt-4o

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=                  # From @BotFather
ALLOWED_CHAT_ID=                     # Send /chatid to your bot

# === OpenCode CLI (Deep Tasks) ===
OPENCODE_SERVER_PORT=4096
OPENCODE_SERVER_ENABLED=true

# === Voice: STT ===
GROQ_API_KEY=your_groq_api_key

# === Voice: TTS ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id
GRADIUM_API_KEY=your_gradium_api_key

# === Dashboard ===
DASHBOARD_TOKEN=generate_with_node_crypto
DASHBOARD_PORT=3141

# === Meeting Bot ===
PIKA_API_KEY=your_pika_api_key
RECALL_API_KEY=your_recall_api_key

# === Security (all optional) ===
# SECURITY_PIN_HASH=salt:hash
# IDLE_LOCK_MINUTES=30
# EMERGENCY_KILL_PHRASE=shutdown everything now

# === Runtime ===
LOG_LEVEL=info
AGENT_MAX_TURNS=30
TASK_TIMEOUT_NIM_MS=60000
TASK_TIMEOUT_OPENCODE_MS=900000
SHOW_COST_FOOTER=compact

# === Obsidian Sync ===
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
