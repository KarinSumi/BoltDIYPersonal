# === REQUIRED ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ALLOWED_CHAT_ID=your_telegram_chat_id

# === AI API ===
OPENCODE_API_KEY=your_nvidia_nim_api_key
OPENCODE_API_BASE_URL=https://integrate.api.nvidia.com/v1
OPENCODE_MODEL=deepseek-ai/deepseek-v4-flash

# === Voice: STT ===
GROQ_API_KEY=your_groq_api_key

# === Voice: TTS ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id
GRADIUM_API_KEY=your_gradium_api_key

# === Dashboard ===
DASHBOARD_TOKEN=generate_with_node_crypto
DASHBOARD_PORT=3141

# === Meeting Bot ===
PIKA_API_KEY=your_pika_api_key
RECALL_API_KEY=your_recall_api_key

# === Security (all optional) ===
# SECURITY_PIN_HASH=salt:hash
# IDLE_LOCK_MINUTES=30
# EMERGENCY_KILL_PHRASE=shutdown everything now

# === Runtime ===
LOG_LEVEL=info
AGENT_MAX_TURNS=30
AGENT_TIMEOUT_MS=900000
SHOW_COST_FOOTER=compact

# === Obsidian Sync ===
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
